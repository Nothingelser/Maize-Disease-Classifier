# ============================================
# Maize Disease Classifier - Environment Variables
# ============================================
# Copy this file to .env and update values
# ============================================

# Flask Configuration
FLASK_ENV=development
FLASK_APP=run_professional.py
SECRET_KEY=your-secret-key-here-change-in-production-2024

# Database Configuration
# For development (SQLite):
# DATABASE_URL=sqlite:///app.db

# For Supabase direct Postgres:
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.<project-ref>.supabase.co:5432/postgres

# Optional Supabase/session pooler fallback for local development:
# DATABASE_POOLER_URL=postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:5432/postgres

# Redis Configuration (for rate limiting and caching)
REDIS_URL=redis://localhost:6379/0

# Model Configuration
MODEL_PATH=models/maize_disease_classifier.pkl

# API Configuration
API_RATE_LIMIT=100
MAX_BATCH_SIZE=10

# JWT Configuration
JWT_EXPIRATION_HOURS=24

# Logging
LOG_LEVEL=INFO

# Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ADMIN_EMAIL=admin@maizeclassifier.com

# Monitoring (optional)
SENTRY_DSN=
NEW_RELIC_LICENSE_KEY=

# Security (production only)
# SESSION_COOKIE_SECURE=True
# REMEMBER_COOKIE_SECURE=True

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5000,http://localhost:3000

# Feature Flags
ENABLE_CACHE=True
ENABLE_RATE_LIMITING=True
ENABLE_ASYNC_PREDICTIONS=False

# Image Settings
IMG_SIZE=128
IMG_CHANNELS=3

# Model Classes
CLASS_NAMES=Blight,Gray Leaf Spot,Healthy,Maize Rust
